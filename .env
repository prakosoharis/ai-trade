# Copy this file to .env before running docker compose.
PROJECT_NAME=ai-research-workbench

POSTGRES_DB=airesearch
POSTGRES_USER=airesearch
POSTGRES_PASSWORD=airesearch
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_HOST_PORT=5438

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_HOST_PORT=6388

API_PORT=8085
WEB_PORT=3060
ADMINER_PORT=8080

# Frontend calls the API from the browser using localhost.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8085

# For single-instance deployment, set this to your server IP or domain.
# Example: NEXT_PUBLIC_API_BASE_URL=http://YOUR_SERVER_IP:8085
